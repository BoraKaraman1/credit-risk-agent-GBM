FROM golang:1.26 AS gobuild

WORKDIR /src

COPY go/go.mod go/go.sum ./
RUN go mod download

COPY go/ ./
RUN CGO_ENABLED=0 go build -o /out/gbm .

FROM apache/airflow:2.8.4-python3.11

USER root
RUN apt-get update \
    && apt-get install -y --no-install-recommends libgomp1 \
    && rm -rf /var/lib/apt/lists/*
USER airflow

ENV PYTHONPATH=/opt/airflow \
    LOG_LEVEL=INFO \
    CREDIT_RISK_GO_BIN=/opt/airflow/bin \
    CREDIT_RISK_DATA_DIR=/opt/airflow/data \
    CREDIT_RISK_STRICT_DQ=true \
    PYTHON_BIN=python

# Install pipeline deps under Airflow's official constraints so shared
# libraries (SQLAlchemy, Flask, pandas) stay at the versions the pinned
# apache/airflow base was tested with. The repo-wide constraints.txt
# pins SQLAlchemy 2.x / Flask 3.x, which break Airflow 2.8 at runtime.
ARG AIRFLOW_CONSTRAINTS=https://raw.githubusercontent.com/apache/airflow/constraints-2.8.4/constraints-3.11.txt
COPY requirements/base.txt requirements/pipeline.txt requirements/agent.txt /tmp/requirements/
RUN pip install --no-cache-dir -c ${AIRFLOW_CONSTRAINTS} \
    -r /tmp/requirements/pipeline.txt
# The scientific stack must then be lifted to the repo pins
# (constraints.txt): model artifacts pickled under numpy 2 by local or
# pipeline-image runs cannot be loaded under the numpy 1.x that
# Airflow's constraint set pins. Airflow's web stack (SQLAlchemy,
# Flask) stays at the base image versions. The advisory review agent
# rides along here because it needs httpx newer than Airflow's pin.
COPY requirements/constraints.txt /tmp/requirements/
RUN pip install --no-cache-dir -c /tmp/requirements/constraints.txt \
    numpy pandas pyarrow scikit-learn scipy lightgbm joblib \
    && pip install --no-cache-dir -r /tmp/requirements/agent.txt

COPY --chown=airflow:0 dags/ /opt/airflow/dags/
COPY --chown=airflow:0 pipeline/ /opt/airflow/pipeline/
COPY --chown=airflow:0 agents/ /opt/airflow/agents/
# Cross-language threshold contract, loaded eagerly by pipeline/config.py
# at import (ROOT-relative, so it must live under /opt/airflow).
COPY --chown=airflow:0 go/shared/config/contract.json /opt/airflow/go/shared/config/contract.json
COPY --from=gobuild --chown=airflow:0 /out/ /opt/airflow/bin/

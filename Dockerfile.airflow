FROM golang:1.26 AS gobuild

WORKDIR /src

COPY go/go.mod go/go.sum ./
RUN go mod download

COPY go/ ./
RUN CGO_ENABLED=0 go build -o /out/gbm .

FROM apache/airflow:2.8.4-python3.11

USER root
RUN apt-get update \
    && apt-get install -y --no-install-recommends libgomp1 \
    && rm -rf /var/lib/apt/lists/*
USER airflow

ENV PYTHONPATH=/opt/airflow \
    LOG_LEVEL=INFO \
    CREDIT_RISK_GO_BIN=/opt/airflow/bin \
    CREDIT_RISK_DATA_DIR=/opt/airflow/data \
    CREDIT_RISK_STRICT_DQ=true \
    PYTHON_BIN=python

# Pin pipeline deps to known-good versions (constraints.txt) so the image
# build is reproducible and does not silently pull untested upgrades onto
# the pinned apache/airflow base. (Reconciling these against Airflow's own
# constraints file requires moving to an Airflow release compatible with
# great-expectations >= 1.0; tracked as a follow-up.)
COPY requirements/base.txt requirements/pipeline.txt requirements/agent.txt requirements/constraints.txt /tmp/requirements/
RUN pip install --no-cache-dir -c /tmp/requirements/constraints.txt \
    -r /tmp/requirements/pipeline.txt -r /tmp/requirements/agent.txt

COPY --chown=airflow:0 dags/ /opt/airflow/dags/
COPY --chown=airflow:0 pipeline/ /opt/airflow/pipeline/
COPY --chown=airflow:0 agents/ /opt/airflow/agents/
COPY --from=gobuild --chown=airflow:0 /out/ /opt/airflow/bin/

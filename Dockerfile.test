FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends libgomp1 \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --system app \
    && useradd --system --gid app --create-home app

COPY requirements/ ./requirements/
RUN pip install --upgrade pip \
    && pip install -c requirements/constraints.txt -r requirements/test.txt

COPY pipeline/ ./pipeline/
COPY tests/ ./tests/
# The suite also covers the UI helpers, DAG integrity (AST layer), and
# the review agent's deterministic plumbing, and pipeline/config.py +
# ui/core.py load the cross-language contract at import.
COPY ui/ ./ui/
COPY dags/ ./dags/
COPY agents/ ./agents/
COPY pytest.ini ./
COPY docker-compose.yml ./
COPY go/shared/config/contract.json go/shared/config/contract.json

USER app

CMD ["python", "-m", "pytest", "-q"]

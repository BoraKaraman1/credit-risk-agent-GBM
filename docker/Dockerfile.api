# FastAPI scoring service
FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# libgomp1 is needed by scikit-learn / shap on slim images
RUN apt-get update \
 && apt-get install -y --no-install-recommends libgomp1 \
 && rm -rf /var/lib/apt/lists/*

COPY requirements.txt ./
RUN pip install -r requirements.txt google-cloud-storage

COPY api ./api

# data/models/champion may be baked in for local-only runs; in the cluster we
# set MODELS_URI=gs://... and the API downloads the champion at startup.
COPY data/models ./data/models

EXPOSE 8000

CMD ["uvicorn", "api.scoring_service:app", "--host", "0.0.0.0", "--port", "8000"]
